```javascript
function generateRecommendationReasoning(user) {
  const d = user.persona === 'priority' ? MOCK_DATA_PRIORITY : MOCK_DATA_PTU;
  const reasons = [];
  const rec = { offer: '', headline: '', bullets: [] };

  // --- Derive workload characteristics from data ---
  const isSpiky       = user.persona === 'priority'; // from history variance
  const is247         = user.persona === 'ptu';
  const highThrottle  = d.throttledCallsPct > 0.05;   // >5% = significant
  const lowCache      = d.cacheMatchRate < 0.20;
  const highQuota     = d.quotaAllocatedTPM / d.quotaLimitTPM > 0.50;
  const latencySensitive = d.throttledCallsPct > 0.05 || d.avgLatencyMs > 1200;

  // --- Priority Processing offer criteria ---
  // Source: https://devblogs.microsoft.com/foundry/whats-new-in-microsoft-foundry-oct-nov-2025/
  // "Pay-as-you-go simplicity with no long-term commitments.
  //  Business-hour or bursty traffic that benefits from scalable, cost-efficient performance."
  const fitsPriority = isSpiky && highThrottle && !highQuota;

  // --- PTU offer criteria ---
  // Source: https://learn.microsoft.com/azure/ai-services/openai/concepts/provisioned-throughput
  // "Provisioned deployments are recommended for workloads with consistent usage
  //  that require predictable latency and throughput."
  const fitsPTU = is247 && (highQuota || d.throttledCallsPct > 0.01);

  if (fitsPriority) {
    rec.offer    = 'Priority Processing';
    rec.headline = 'Your usage pattern — high throttle rate during business hours with variable overnight volume — matches the design target for Priority Processing.';
    rec.bullets  = [];

    if (highThrottle)
      rec.bullets.push(`${(d.throttledCallsPct * 100).toFixed(1)}% throttled calls in the last 30 days → Standard is blocking users at peak; Priority Processing routes your requests ahead of Standard queue, no capacity reservation needed.`);

    if (isSpiky)
      rec.bullets.push(`Spiky workload (business hours only) → PTU capacity would sit unused overnight. Priority Processing is PAYG — you only pay for what you use.`);

    if (lowCache)
      rec.bullets.push(`${(d.cacheMatchRate * 100).toFixed(0)}% cache match rate → PTU economics improve significantly with high cache reuse (typically >40%). At ${(d.cacheMatchRate * 100).toFixed(0)}%, PTU breakeven is harder to justify.`);

    rec.bullets.push(`Priority Processing shares the same quota pool as Standard — no commitment, no capacity reservation — but your requests are processed ahead of Standard requests in the routing queue.`);
    // Source: https://techcommunity.microsoft.com/blog/azure-ai-foundry-blog/integrating-azure-ai-foundry-with-copilot-studio/4457370
    // "Priority processing uses the same quota as standard processing."

    rec.bullets.push(`Unpredictable caseload → no need to forecast monthly token volume for PTU sizing. Priority Processing scales with actual usage.`);
  }

  if (fitsPTU) {
    rec.offer    = 'Provisioned Throughput (PTU)';
    rec.headline = 'Your consistent 24/7 workload with growing quota utilization matches the design target for Provisioned Throughput.';
    rec.bullets  = [];

    if (highQuota)
      rec.bullets.push(`${((d.quotaAllocatedTPM / d.quotaLimitTPM) * 100).toFixed(0)}% quota utilization → approaching the Standard TPM rate limit. PTU provides dedicated capacity outside the shared quota pool, eliminating rate limit risk.`);

    rec.bullets.push(`24/7 consistent load → PTU dedicated capacity is fully utilized around the clock. Unlike Standard, your reserved GPU throughput is never idle.`);

    if (d.cacheMatchRate === 0)
      rec.bullets.push(`Current cache match rate: 0% → opportunity to reach 50% with prompt optimization. At 50% cache, PTU throughput doubles from ${d.peakRPM} to ${d.projectedRPMWithCache} RPM on the same ${d.recommendedPTUs} PTUs — zero additional cost. (Source: Chris Hoder, Azure AI Foundry Ignite 2025 demo)`);

    rec.bullets.push(`PTU provides a dedicated GPU lane: latency is predictable at ~${d.projectedLatencyMs}ms (with cache) vs variable Standard latency. SLA is guaranteed within purchased capacity.`);
    // Source: https://learn.microsoft.com/azure/ai-services/openai/concepts/provisioned-throughput

    rec.bullets.push(`Foundry PTU calculator recommends ${d.recommendedPTUs} PTUs for your ${(d.peakInputTPM / 1000000).toFixed(2)}M peak TPM → $${(d.recommendedPTUs * 260).toLocaleString()}/month. Scales predictably; not exposed to token price growth.`);
  }

  return rec;
}
```


function generateMockHistory() {
  const points = [];
  for (let i = 0; i < 60; i++) {
    let rpm, tpm, cacheRate, util, ttlb;
    if (i < 20) {
      // Phase 1: Standard Global deployment baseline
      rpm = 220 + Math.round((Math.random() - 0.5) * 15);
      tpm = 3300000 + Math.round((Math.random() - 0.5) * 100000);
      cacheRate = 0;
      util = null; // N/A for standard
      ttlb = 1350 + Math.round((Math.random() - 0.5) * 80);
    } else if (i < 40) {
      // Phase 2: PTU, no cache yet
      rpm = 254 + Math.round((Math.random() - 0.5) * 12);
      tpm = 3880000 + Math.round((Math.random() - 0.5) * 120000);
      cacheRate = 0;
      util = 112 + Math.round((Math.random() - 0.5) * 3);
      ttlb = 1300 + Math.round((Math.random() - 0.5) * 60);
    } else {
      // Phase 3: PTU + 50% cache match
      rpm = 437 + Math.round((Math.random() - 0.5) * 20);
      tpm = 6680000 + Math.round((Math.random() - 0.5) * 200000);
      cacheRate = 0.50 + (Math.random() - 0.5) * 0.04;
      util = 100 + Math.round((Math.random() - 0.5) * 2);
      ttlb = 1100 + Math.round((Math.random() - 0.5) * 50);
    }
    points.push({ minutesAgo: 60 - i, rpm, tpm, cacheRate, util, ttlb });
  }
  return points;
}
```

